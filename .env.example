# ── Profile ────────────────────────────────────────────────────────────────────
# Change this to "home" when accessing via Tailscale, "office" when on-site
DB_PROFILE=office

# ── Database hosts ─────────────────────────────────────────────────────────────
DB_HOST_OFFICE=192.168.x.x       # LAN IP of your SQL Server (office)
DB_HOST_HOME=100.x.x.x           # Tailscale IP of your SQL Server (home)

# ── Database credentials ───────────────────────────────────────────────────────
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=your-db-password-here
DB_NAME=BankingDB

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRY_SECONDS=3600

# ── Server ─────────────────────────────────────────────────────────────────────
API_PORT=5000
DEBUG=false

# ── Routing ────────────────────────────────────────────────────────────────────
# Full URL: gateway / SERVICE_DOMAIN / api / API_VERSION / endpoint
# e.g.      http://localhost:8080/banking/api/v1/clients/
SERVICE_DOMAIN=banking
API_VERSION=v1
