{
  "api_id": "banking-api-v1",
  "org_id": "default",
  "name": "Banking System API",
  "definition": {
    "location": "header",
    "key": "x-api-version"
  },
  "use_keyless": false,
  "auth": {
    "use_param": false,
    "use_cookie": false,
    "auth_header_name": "x-api-key"
  },
  "version_data": {
    "not_versioned": true,
    "versions": {
      "Default": {
        "name": "Default",
        "use_extended_paths": true,
        "extended_paths": {
          "white_list": [],
          "black_list": [],
          "ignored": [
            {
              "path": "/review",
              "method_actions": {
                "GET": { "action": "no_action", "code": 200, "data": "", "headers": {} }
              }
            },
            {
              "path": "/doc",
              "method_actions": {
                "GET": { "action": "no_action", "code": 200, "data": "", "headers": {} }
              }
            }
          ]
        }
      }
    }
  },
  "proxy": {
    "listen_path": "/banking/",
    "target_url": "http://banking-api:5000",
    "strip_listen_path": false
  },
  "active": true,
  "tags": ["banking", "v1"]
}
